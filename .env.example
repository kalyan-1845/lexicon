# ==============================================================================
# Lexicon AI — Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Settings (FastAPI)
# ------------------------------------------------------------------------------
# Host/Port for backend server (uvicorn)
HOST=0.0.0.0
PORT=8000

# LLM Providers Configuration
# To use OpenAI models
OPENAI_API_KEY=your_openai_api_key_here

# To use Groq models (Fast inference)
GROQ_API_KEY=your_groq_api_key_here

# To use local models via Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Database URLs
# SQLite fallback (development)
# DATABASE_URL=sqlite:///./lexicon.db
# PostgreSQL with pgvector (production/docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lexicon

# ------------------------------------------------------------------------------
# Frontend Settings (Next.js)
# ------------------------------------------------------------------------------
# API endpoints mapping
NEXT_PUBLIC_API_URL=http://localhost:8000
